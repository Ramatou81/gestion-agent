<div class="p-8">
  <h1 class="text-2xl font-bold text-slate-900 mb-6">Mon Équipe</h1>

  <!-- Affichage du Manager -->
  <% if current_user.present? %>
    <div class="mb-8 bg-indigo-50 rounded-2xl shadow-sm p-6 border border-indigo-200">
      <div class="flex items-center space-x-4">
        <!-- Initiales du manager -->
        <div class="h-14 w-14 rounded-full bg-indigo-200 flex items-center justify-center text-indigo-700 font-bold text-lg">
          <%= current_user.first_name[0].upcase if current_user.first_name.present? %><%= current_user.last_name[0].upcase if current_user.last_name.present? %>
        </div>
        <div>
          <!-- Nom complet du Manager -->
          <h2 class="font-bold text-slate-900 text-lg"><%= current_user.first_name %> <%= current_user.last_name %></h2>
          <!-- Email -->
          <p class="text-sm text-slate-600"><%= current_user.email %></p>
          <p class="text-xs font-semibold text-indigo-600">Manager</p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Affichage des Agents -->
  <% if @agents.any? %>
    <h2 class="text-xl font-semibold text-slate-800 mb-4">Mes Agents</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @agents.each do |agent| %>
        <div class="bg-white rounded-2xl shadow-md p-6 border border-slate-100 hover:shadow-lg transition-all duration-300">
          <div class="flex items-center space-x-4 mb-4">
            <!-- Initiales de l'agent -->
            <div class="h-12 w-12 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 font-bold">
              <%= agent.first_name[0].upcase if agent.first_name.present? %><%= agent.last_name[0].upcase if agent.last_name.present? %>
            </div>
            <div>
              <!-- Nom complet -->
              <h2 class="font-semibold text-slate-900"><%= agent.first_name %> <%= agent.last_name %></h2>
              <!-- Email -->
              <p class="text-sm text-slate-500"><%= agent.email %></p>
            </div>
          </div>
          <!-- Lien vers la page détails -->
          <%= link_to "Voir les détails", manager_agent_path(agent), class: "text-indigo-600 hover:text-indigo-700 font-medium transition-colors text-sm" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-slate-500">Aucun agent trouvé.</p>
  <% end %>
</div>
