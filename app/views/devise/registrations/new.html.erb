<div class="max-w-md mx-auto mt-16 p-8 bg-white rounded-2xl shadow-2xl">
  <h2 class="text-4xl font-bold text-center text-gray-900 mb-2">Créer un compte</h2>
  <p class="text-center text-sm text-gray-500 mb-6">
    Rejoignez-nous et commencez votre aventure dès maintenant.
  </p>

  <%= form_with model: resource, url: registration_path(resource_name), local: true, class: "space-y-6" do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="space-y-4">
      <div>
        <%= f.label :email, "Adresse e-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, placeholder: "nom@example.com", class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-purple-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "new-password", required: true, placeholder: "••••••••", class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-purple-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password_confirmation, "Confirmer le mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", required: true, placeholder: "••••••••", class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-purple-500 sm:text-sm" %>
      </div>
    </div>

    <div>
      <%= f.submit "Créer un compte", class: "w-full py-2 px-4 bg-pink-600 hover:bg-pink-700 text-white font-semibold text-sm rounded-lg shadow-md transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm text-gray-600">
    <p>Déjà un compte ? 
      <%= link_to "Se connecter", new_session_path(resource_name), class: "text-pink-600 hover:text-purple-500 font-medium" %>
    </p>
  </div>
</div>
