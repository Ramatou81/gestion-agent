
<div class="max-w-md mx-auto mt-16 p-8 bg-white rounded-2xl shadow-2xl">
  <h2 class="text-4xl font-bold text-center text-gray-900 mb-2">Se connecter</h2>
  <p class="text-center text-sm text-gray-500 mb-6">
    Heureux de vous revoir ! Connectez-vous pour accéder à votre espace.
  </p>

  <%= form_with scope: resource_name, url: session_path(resource_name), local: true, html: { data: { turbo: false } }, class: "space-y-6" do |f| %>
    <div class="space-y-4">
      <div>
        <%= f.label :email, "Adresse e-mail", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, placeholder: "nom@example.com", class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-purple-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :password, "Mot de passe", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password", required: true, placeholder: "••••••••", class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-purple-500 sm:text-sm" %>
      </div>
    </div>

    <div class="flex items-center justify-between text-sm">
      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-pink-600 focus:ring-purple-500 border-gray-300 rounded" %>
          <%= f.label :remember_me, "Se souvenir de moi", class: "ml-2 text-gray-700" %>
        </div>
      <% end %>

      <%= link_to "Mot de passe oublié ?", new_password_path(resource_name), class: "text-purple-600 hover:text-purple-500 font-medium" %>
    </div>

    <div>
      <%= f.submit "Se connecter", class: "w-full py-2 px-4 bg-purple-600 hover:bg-purple-700 text-white font-semibold text-sm rounded-lg shadow-md transition duration-150 ease-in-out focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-purple-500" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm text-gray-600">
    <p>Vous n'avez pas de compte ? 
      <%= link_to "Créer un compte", new_registration_path(resource_name), class: "text-pink-600 hover:text-purple-500 font-medium" %>
    </p>
  </div>
</div>


