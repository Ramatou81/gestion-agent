<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-xl text-center space-y-6">
  <h2 class="text-3xl font-extrabold text-gray-900">Mot de passe oublié ?</h2>
  <p class="mt-2 text-sm text-gray-600">
    Pas de panique ! Entrez votre adresse e-mail ci-dessous et nous vous enverrons les instructions pour le réinitialiser.
  </p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-6" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "sr-only" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", required: true, placeholder: "Adresse e-mail", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.submit "Envoyer les instructions", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-pink-600 hover:bg-pink-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-pink-500 transition duration-150 ease-in-out cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 text-sm text-gray-600 space-y-2">
    <p>
      <%= link_to "Retour à la connexion", new_session_path(resource_name), class: "font-medium text-pink-600 hover:text-pink-500" %>
    </p>
    <p>
      <%= link_to "Créer un compte", new_registration_path(resource_name), class: "font-medium text-pink-600 hover:text-pink-500" %>
    </p>
  </div>
</div>
