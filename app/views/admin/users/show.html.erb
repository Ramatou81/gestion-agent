
<div class="max-w-3xl mx-auto p-6 md:p-8 bg-white rounded-2xl shadow-xl border border-gray-100">

  <!-- Header avec bouton retour -->
  <div class="flex items-center mb-8">
    <%= link_to admin_users_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
      <i class="fas fa-arrow-left text-2xl"></i>
    <% end %>
    <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 ml-6 tracking-tight">
      Détails de l'utilisateur
    </h1>
  </div>

  <!-- Card utilisateur -->
  <div class="bg-white rounded-3xl shadow-2xl overflow-hidden border border-gray-100">
    <div class="p-8 lg:p-12">
      <!-- Avatar et nom -->
      <div class="flex items-center space-x-6 mb-8">
        <div class="h-20 w-20 rounded-full bg-pink-100 flex items-center justify-center text-pink-600 text-3xl font-bold border-4 border-pink-100">
          <i class="fas fa-user"></i>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-gray-900">
            <%= @user.name %>
          </h2>
          <p class="text-sm text-gray-500 mt-1">
            <%= @user.role_name %>
          </p>
        </div>
      </div>

      <!-- Informations personnelles et professionnelles -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8 mt-10">
        <!-- Informations personnelles -->
        <div>
          <h3 class="text-lg font-semibold text-gray-700 mb-4">Informations personnelles</h3>
          <div class="space-y-4">
            <p><span class="font-medium">Prénom :</span> <%= @user.first_name || "—" %></p>
            <p><span class="font-medium">Nom :</span> <%= @user.last_name || "—" %></p>
            <p><span class="font-medium">Email :</span> <%= @user.email || "—" %></p>
            <p><span class="font-medium">Téléphone :</span> <%= @user.phone.presence || "—" %></p>
            <p><span class="font-medium">Adresse :</span> <%= @user.address.presence || "—" %></p>
            <p><span class="font-medium">Date de naissance :</span> <%= @user.birth_date&.strftime("%d %b %Y") || "—" %></p>
          </div>
        </div>

        <!-- Informations professionnelles -->
        <div>
          <h3 class="text-lg font-semibold text-gray-700 mb-4">Informations professionnelles</h3>
          <div class="space-y-4">
            <p><span class="font-medium">Département :</span> <%= @user.department&.name || "—" %></p>
            <p><span class="font-medium">Date d'embauche :</span> <%= @user.hire_date&.strftime("%d %b %Y") || "—" %></p>
            <p><span class="font-medium">Rôle :</span> <%= @user.role_name %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Actions -->
    <div class="bg-gray-50 p-6 lg:p-8 flex flex-col md:flex-row justify-between md:justify-end md:space-x-4">
      <%= link_to edit_admin_user_path(@user), class: "w-full md:w-auto px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg shadow-md hover:bg-blue-700 transition duration-300 transform hover:scale-105 flex items-center justify-center mb-3 md:mb-0" do %>
        <i class="fas fa-edit mr-2"></i> Modifier
      <% end %>

      <%= button_to admin_user_path(@user),
            method: :delete,
            data: { confirm: "Êtes-vous sûr de vouloir supprimer cet utilisateur ?" },
            class: "w-full md:w-auto px-6 py-3 bg-red-600 text-white font-semibold rounded-lg shadow-md hover:bg-red-700 transition duration-300 transform hover:scale-105 flex items-center justify-center" do %>
        <i class="fas fa-trash-alt mr-2"></i> Supprimer
      <% end %>
    </div>
  </div>
</div>
