
<div class="max-w-md mx-auto p-8 bg-white rounded-2xl shadow-2xl">
  <h2 class="text-3xl font-bold text-center text-gray-900 mb-2">Créer un nouvel agent</h2>
  <p class="text-center text-sm text-gray-500 mb-6">
    Remplissez les informations ci-dessous pour ajouter un nouveau membre à votre équipe.
  </p>

  <%= form_with(model: @agent, url: admin_agents_path, local: true, class: "space-y-4") do |f| %>

    <!-- Nom et Prénom -->
    <div class="grid grid-cols-1 gap-4">
      <div>
        <%= f.label :last_name, "Nom", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :last_name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :first_name, "Prénom", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :first_name, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :email, "Adresse email", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :phone, "Numéro de téléphone", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :phone, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :birth_date, "Date de naissance", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :birth_date, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :address, "Adresse", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :position, "Poste", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :position, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :hire_date, "Date d'embauche", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.date_field :hire_date, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :status, "Statut", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :status, ["active", "inactive"], {}, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>

      <div>
        <%= f.label :department_id, "Département", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.collection_select :department_id, Department.all, :id, :name, {prompt: "Sélectionner un département"}, class: "w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:outline-none focus:ring-2 focus:ring-pink-500 focus:border-pink-500 sm:text-sm" %>
      </div>
    </div>

   <!-- Boutons -->
<div class="flex items-center justify-between">
  <%= link_to "Annuler", admin_agents_path, class: "text-gray-600 hover:text-gray-900 text-sm font-medium" %>
  <%= f.submit "Créer l'agent", class: "px-6 py-2 bg-pink-600 hover:bg-pink-700 text-white rounded-lg font-semibold transition-colors" %>
</div>

<div class="mt-6 text-center text-sm text-gray-600">
  <%= link_to "Retour à la liste des agents", admin_agents_path, class: "text-pink-600 hover:underline font-medium" %>
</div>
  <% end %>
</div>
