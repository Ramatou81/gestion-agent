
<div class="max-w-md mx-auto p-8 bg-white rounded-2xl shadow-2xl">
  <h2 class="text-3xl font-bold text-center text-gray-900 mb-2">Modifier l'agent</h2>

  <% if @agent.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-4 rounded-lg mb-6">
      <h2 class="font-bold mb-2">
        <%= pluralize(@agent.errors.count, "erreur") %> a empêché l'enregistrement de cet agent :
      </h2>
      <ul class="list-disc list-inside space-y-1">
        <% @agent.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

<%= form_with(model: [:admin, @agent], local: true, class: "space-y-4") do |f| %>

    <!-- Informations personnelles -->
    <div class="space-y-4">
      <% [:first_name, :last_name, :email, :phone, :birth_date, :address].each do |field| %>
  <div>
    <%= f.label field, field.to_s.humanize, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <% if field == :birth_date %>
      <%= f.date_field field, class: "w-full px-4 py-2 ..." %>
    <% else %>
      <%= f.text_field field, class: "w-full px-4 py-2 ..." %>
    <% end %>
  </div>
<% end %>

    <!-- Informations professionnelles -->
    <div>
  <%= f.label :position, "Poste", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.text_field :position, placeholder: "Poste occupé", class: "w-full px-4 py-2 border border-gray-300 rounded-lg ..." %>
</div>

<div>
  <%= f.label :hire_date, "Date d'embauche", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.date_field :hire_date, class: "w-full px-4 py-2 border border-gray-300 rounded-lg ..." %>
</div>

<div>
  <%= f.label :status, "Statut", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.select :status, ["active", "inactive"], {}, class: "w-full px-4 py-2 border border-gray-300 rounded-lg ..." %>
</div>

<div>
  <%= f.label :department_id, "Département", class: "block text-sm font-medium text-gray-700 mb-1" %>
  <%= f.collection_select :department_id, Department.all, :id, :name, { prompt: "Sélectionner un département" }, class: "w-full px-4 py-2 border border-gray-300 rounded-lg ..." %>
</div>


    <!-- Boutons -->
    <div class="pt-6 flex flex-col sm:flex-row gap-3 sm:gap-4">
      <%= f.submit "Enregistrer les modifications", class: "w-full sm:w-auto inline-flex justify-center items-center px-6 py-3 bg-pink-600 hover:bg-pink-700 text-white font-semibold rounded-xl shadow-lg transition transform hover:scale-[1.01]" %>
      <%= link_to "Annuler",  admin_agents_path, class: "w-full sm:w-auto text-center px-6 py-3 border-2 border-pink-300 text-pink-700 font-semibold rounded-xl hover:bg-pink-50 transition" %>
    </div>
  <% end %>

  <div class="mt-6 text-center text-sm text-pink-700">
    <%= link_to "Retour à la liste des agents", admin_agents_path, class: "hover:underline font-medium" %>
  </div>
</div>
