

<div class="max-w-3xl mx-auto p-6 md:p-8 bg-white rounded-2xl shadow-xl border border-gray-100">

  <div class="flex items-center space-x-6 pb-6 border-b border-gray-200">
    <div class="h-16 w-16 md:h-20 md:w-20 bg-pink-100 rounded-full flex-shrink-0 flex items-center justify-center text-pink-700 font-bold text-2xl">
      <%= @agent.first_name.first %><%= @agent.last_name.first %>
    </div>
    <div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight">
        <%= @agent.first_name %> <%= @agent.last_name %>
      </h1>
      <p class="text-lg md:text-xl text-pink-600 font-medium italic mt-1">
        <%= @agent.position %>
      </p>
    </div>
  </div>

  <div class="mt-8 space-y-6">
    <!-- Détails de contact -->
    <div>
      <h2 class="text-xl font-bold text-pink-700 mb-4">Détails de contact</h2>
      <div class="space-y-3">
        <div class="flex items-center space-x-3">
          <i class="fas fa-envelope text-pink-500 text-lg"></i>
          <p class="text-gray-700 text-base"><%= @agent.email %></p>
        </div>
        <div class="flex items-center space-x-3">
          <i class="fas fa-phone-alt text-pink-500 text-lg"></i>
          <p class="text-gray-700 text-base"><%= @agent.phone %></p>
        </div>
        <div class="flex items-center space-x-3">
          <i class="fas fa-calendar-alt text-pink-500 text-lg"></i>
          <p class="text-gray-700 text-base">Date de naissance : <span class="font-semibold"><%= @agent.birth_date || "Non renseigné" %></span></p>
        </div>
        <div class="flex items-center space-x-3">
          <i class="fas fa-map-marker-alt text-pink-500 text-lg"></i>
          <p class="text-gray-700 text-base">Adresse : <span class="font-semibold"><%= @agent.address || "Non renseigné" %></span></p>
        </div>
      </div>
    </div>

    <!-- Informations professionnelles -->
    <div class="pt-6">
      <h2 class="text-xl font-bold text-pink-700 mb-4">Informations professionnelles</h2>
      <div class="space-y-3">
        <div class="flex items-center space-x-3">
          <i class="fas fa-building text-pink-500 text-lg"></i>
          <p class="text-gray-700 text-base">Département : <span class="font-semibold"><%= @agent.department&.name || "Aucun" %></span></p>
        </div>
        <div class="flex items-center space-x-3">
          <i class="fas fa-circle text-lg <%= @agent.status == "active" ? 'text-green-500' : 'text-red-500' %>"></i>
          <p class="text-gray-700 text-base">Statut : <span class="font-semibold"><%= @agent.status.capitalize %></span></p>
        </div>
        <div class="flex items-center space-x-3">
          <i class="fas fa-briefcase text-pink-500 text-lg"></i>
          <p class="text-gray-700 text-base">Date d'embauche : <span class="font-semibold"><%= @agent.hire_date || "Non renseigné" %></span></p>
        </div>
      </div>
    </div>

    <!-- Départements gérés -->
    <% if @agent.managed_departments.any? %>
      <div class="pt-6">
        <h2 class="text-xl font-bold text-pink-700 mb-4">Départements gérés</h2>
        <ul class="list-disc list-inside space-y-1 text-gray-700">
          <% @agent.managed_departments.each do |dept| %>
            <li><%= dept.name %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @agent.subordinates.any? %>
  <div class="pt-6">
    <h2 class="text-xl font-bold text-pink-700 mb-2">Agents supervisés</h2>
    <ul class="list-disc list-inside space-y-1 text-gray-700">
      <% @agent.subordinates.each do |sub| %>
        <li>
          <%= sub.full_name %> (<%= sub.position %>) — Département : <%= sub.department&.name || "Aucun" %>
        </li>
      <% end %>
    </ul>
  </div>
<% end %>


<div class="pt-6">
  <h2 class="text-xl font-bold text-pink-700 mb-4">Historique des présences</h2>

  <% if @attendances.any? %>
    <table class="min-w-full border border-gray-200">
      <thead class="bg-gray-100">
        <tr>
          <th class="px-4 py-2 border">Date</th>
          <th class="px-4 py-2 border">Check-in</th>
          <th class="px-4 py-2 border">Check-out</th>
        </tr>
      </thead>
      <tbody>
        <% @attendances.each do |attendance| %>
          <tr>
            <td class="px-4 py-2 border"><%= attendance.check_in.strftime("%d/%m/%Y") %></td>
            <td class="px-4 py-2 border"><%= attendance.check_in.strftime("%H:%M") %></td>
            <td class="px-4 py-2 border">
              <%= attendance.check_out ? attendance.check_out.strftime("%H:%M") : "Pas encore sorti" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-gray-700">Aucune présence enregistrée.</p>
  <% end %>
</div>



  </div>

  <div class="mt-12 flex flex-col sm:flex-row space-y-3 sm:space-y-0 sm:space-x-4">
  <%= link_to "Modifier le profil", edit_admin_agent_path(@agent), class: "inline-flex items-center justify-center gap-2 bg-pink-600 hover:bg-pink-700 text-white font-semibold py-3 px-6 rounded-xl shadow-lg transform hover:scale-105 transition-all duration-300" %>
  <%= link_to "Retour à la liste", admin_agents_path, class: "inline-flex items-center justify-center gap-2 border-2 border-pink-300 text-pink-700 font-semibold py-3 px-6 rounded-xl hover:bg-pink-50 transition-colors duration-300" %>
</div>

</div>
