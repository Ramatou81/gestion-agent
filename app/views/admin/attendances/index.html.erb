
<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
  
  <div class="flex flex-col md:flex-row md:items-center justify-between mb-8">
    <h1 class="text-4xl font-extrabold text-gray-900 tracking-tight">
      Présences des agents
    </h1>
    <%= link_to new_admin_attendance_path, class: "mt-4 md:mt-0 px-6 py-3 bg-pink-600 text-white font-semibold rounded-lg shadow-md hover:bg-pink-700 transition duration-300 transform hover:scale-105" do %>
      <i class="fas fa-plus mr-2"></i> Nouvelle présence
    <% end %>
  </div>

  <div class="overflow-x-auto rounded-xl shadow-lg border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr class="text-gray-600 text-sm uppercase tracking-wider">
          <th scope="col" class="py-4 px-6 text-left font-bold">Agent</th>
          <th scope="col" class="py-4 px-6 text-left font-bold">Date</th>
          <th scope="col" class="py-4 px-6 text-left font-bold">Statut</th>
          <th scope="col" class="py-4 px-6 text-left font-bold">Heure d'arrivée</th>
          <th scope="col" class="py-4 px-6 text-left font-bold">Heure de départ</th>
          <th scope="col" class="py-4 px-6 text-left font-bold">Actions</th>
        </tr>
      </thead>
     
<tbody class="bg-white divide-y divide-gray-200">
  <% @attendances.each do |attendance| %>
    <tr class="hover:bg-gray-50 transition-colors">
      <!-- Agent -->
      <!-- Agent -->
<td class="py-4 px-6 whitespace-nowrap text-sm font-medium text-gray-900">
  <% if attendance.agent %>
    <%= attendance.agent.name %>
  <% else %>
    Non assigné
  <% end %>
</td>


      <!-- Date du check-in -->
      <td class="py-4 px-6 whitespace-nowrap text-sm text-gray-500">
        <%= attendance.check_in.strftime("%d %b, %Y") %>
      </td>

      <!-- Statut -->
      <td class="py-4 px-6 whitespace-nowrap text-sm">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold
          <%= attendance.status == 'Présent' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
          <i class="fas <%= attendance.status == 'Présent' ? 'fa-check-circle' : 'fa-times-circle' %> mr-1"></i>
          <%= attendance.status %>
        </span>
      </td>

      <!-- Heure d'arrivée -->
      <td class="py-4 px-6 whitespace-nowrap text-sm">
        <%= attendance.check_in.strftime("%H:%M") %>
      </td>

      <!-- Heure de départ -->
      <td class="py-4 px-6 whitespace-nowrap text-sm">
        <%= attendance.check_out ? attendance.check_out.strftime("%H:%M") : "Pas encore sorti" %>
      </td>

      <!-- Actions -->
      <td class="py-4 px-6 whitespace-nowrap text-sm font-medium space-x-2">
        <%= link_to admin_attendance_path(attendance), class: "text-pink-600 hover:text-pink-900" do %>
          <i class="fas fa-eye"></i>
        <% end %>
        <%= link_to edit_admin_attendance_path(attendance), class: "text-purple-600 hover:text-purple-900" do %>
          <i class="fas fa-edit"></i>
        <% end %>
        <%= button_to "Supprimer", admin_attendance_path(attendance),
              method: :delete,
              data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer cette présence ?" },
              class: "px-3 py-1 bg-red-600 text-white rounded-lg hover:bg-red-700 transition",
              form: { class: "inline-block m-0 p-0" } %>
      </td>
    </tr>
  <% end %>
</tbody>
    </table>
  </div>
</div>
