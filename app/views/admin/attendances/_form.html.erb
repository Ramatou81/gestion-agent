

<%= form_with(model: [:admin, @attendance], local: true) do |f| %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
    
    <!-- Agent -->
    <div class="md:col-span-2">
      <%= f.label :agent_id, "Agent", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.collection_select :agent_id, Agent.all, :id, :first_name, { prompt: "Sélectionner un agent" }, class: "block w-full rounded-lg border-gray-300 shadow-sm transition-all duration-200 focus:ring-pink-500 focus:border-pink-500" %>
    </div>

    <!-- Statut -->
    <div>
      <%= f.label :status, "Statut", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.select :status, Attendance::STATUSES, { prompt: "Sélectionner un statut" }, class: "block w-full rounded-lg border-gray-300 shadow-sm transition-all duration-200 focus:ring-pink-500 focus:border-pink-500" %>
    </div>

    <!-- Check-in (date + heure) -->
    <div>
      <%= f.label :check_in, "Heure d'arrivée", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.datetime_local_field :check_in, value: attendance.check_in&.strftime("%Y-%m-%dT%H:%M") || Time.current.strftime("%Y-%m-%dT%H:%M"), class: "block w-full rounded-lg border-gray-300 shadow-sm transition-all duration-200 focus:ring-pink-500 focus:border-pink-500" %>
    </div>

    <!-- Check-out (date + heure) -->
    <div>
      <%= f.label :check_out, "Heure de départ", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.datetime_local_field :check_out, value: attendance.check_out&.strftime("%Y-%m-%dT%H:%M"), class: "block w-full rounded-lg border-gray-300 shadow-sm transition-all duration-200 focus:ring-pink-500 focus:border-pink-500" %>
    </div>
  </div>

  <div class="mt-8">
    <%= f.submit "Enregistrer la présence", class: "px-6 py-3 bg-pink-600 text-white font-semibold rounded-lg shadow-md hover:bg-pink-700 transition duration-300 transform hover:scale-105 cursor-pointer" %>
  </div>
<% end %>
