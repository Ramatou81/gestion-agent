

<div class="max-w-2xl mx-auto py-12 px-4 sm:px-6 lg:px-8 bg-white rounded-2xl shadow-xl border border-gray-100">

  <!-- Nom et manager du département -->
  <h1 class="text-3xl font-extrabold text-gray-900 mb-4"><%= @department.name %></h1>

  <p class="text-gray-700 mb-6">
    <strong>Manager :</strong>
    <% if @department.manager %>
      <span class="text-pink-600 font-semibold"><%= @department.manager.full_name %></span>
    <% else %>
      <em>Aucun</em>
    <% end %>
  </p>

  <!-- Liste des agents du département -->
  <% if @department.agents.any? %>
    <div class="mb-6">
      <h2 class="text-xl font-bold text-pink-700 mb-3">Agents du département</h2>
      <ul class="list-disc list-inside space-y-1 text-gray-700">
        <% @department.agents.each do |agent| %>
          <li>
            <%= agent.full_name %> — <%= agent.position %>
            <% if agent.manager %>
              (Manager : <%= agent.manager.full_name %>)
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  <% else %>
    <p class="text-gray-500 italic mb-6">Aucun agent dans ce département pour le moment.</p>
  <% end %>

  <!-- Boutons -->
  <div class="flex space-x-4">
  <%= link_to "Modifier", edit_admin_department_path(@department), class: "px-4 py-2 bg-pink-600 text-white rounded-lg hover:bg-pink-700 transition" %>
  <%= link_to "Retour à la liste", admin_departments_path, class: "px-4 py-2 bg-pink-50 text-pink-700 rounded-lg hover:bg-pink-100 transition" %>
</div>
</div>
