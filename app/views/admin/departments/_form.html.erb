
<%= form_with(model: @department, url: @department.new_record? ? admin_departments_path : admin_department_path(@department), local: true, class: "space-y-6") do |f| %>
  <% if @department.errors.any? %>
    <div class="bg-red-50 border border-red-200 text-red-800 p-4 rounded-lg">
      <h2 class="font-bold mb-2">
        <%= pluralize(@department.errors.count, "erreur") %> a empêché l'enregistrement :
      </h2>
      <ul class="list-disc list-inside space-y-1">
        <% @department.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Nom du département -->
  <div class="flex flex-col space-y-1">
    <%= f.label :name, "Nom du département", class: "text-sm font-semibold text-gray-700" %>
    <%= f.text_field :name, placeholder: "Nom du département", 
          class: "block w-full rounded-lg border-gray-300 shadow-sm transition-all duration-200 focus:ring-pink-500 focus:border-pink-500 px-4 py-2" %>
  </div>

  <!-- Description -->
  <div class="flex flex-col space-y-1">
    <%= f.label :description, "Description", class: "text-sm font-semibold text-gray-700" %>
    <%= f.text_area :description, rows: 3, placeholder: "Description du département", 
          class: "block w-full rounded-lg border-gray-300 shadow-sm transition-all duration-200 focus:ring-pink-500 focus:border-pink-500 px-4 py-2" %>
  </div>

  <!-- Manager -->
  <div class="flex flex-col space-y-1">
    <%= f.collection_select :manager_id, Agent.all.order(:first_name, :last_name), :id, :full_name,
      { prompt: "Sélectionner un manager" }, 
      { class: "block w-full rounded-lg border-gray-300 shadow-sm px-4 py-2 focus:ring-pink-500 focus:border-pink-500" } %>

  </div>

  <!-- Bouton de soumission -->
  <div class="pt-4">
    <%= f.submit @department.new_record? ? "Créer le département" : "Enregistrer les modifications", 
          class: "w-full py-3 px-6 bg-pink-600 hover:bg-pink-700 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300" %>
  </div>
<% end %>
