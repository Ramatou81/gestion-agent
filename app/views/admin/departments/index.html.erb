
<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <!-- Enhanced Header Section -->
  <div class="flex flex-col md:flex-row md:items-center justify-between mb-8">
    <div class="space-y-1">
      <h1 class="text-4xl font-extrabold bg-gradient-to-r from-slate-800 to-slate-600 bg-clip-text text-transparent">
        Départements
      </h1>
      <p class="text-slate-500">Gérez la structure organisationnelle de l'entreprise</p>
    </div>
    
    <%= link_to new_admin_department_path, 
        class: "group relative px-6 py-3 bg-gradient-to-r from-pink-500 to-purple-500 text-white font-semibold rounded-xl shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5" do %>
      <div class="absolute inset-0 bg-white rounded-xl opacity-0 group-hover:opacity-10 transition-opacity duration-300"></div>
      <i class="fas fa-plus-circle mr-2 group-hover:scale-110 transition-transform duration-300"></i>
      Nouveau département
    <% end %>
  </div>

  <!-- Enhanced Table Container -->
  <div class="bg-white rounded-2xl shadow-lg border border-pink-100/50 overflow-hidden backdrop-blur-xl">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100">
        <!-- Enhanced Table Header -->
        <thead class="bg-gradient-to-r from-slate-50 to-pink-50">
          <tr>
            <th class="py-4 px-6 text-left">
              <span class="text-sm font-bold text-slate-700">Nom</span>
            </th>
            <th class="py-4 px-6 text-left">
              <span class="text-sm font-bold text-slate-700">Manager</span>
            </th>
            <th class="py-4 px-6 text-left">
              <span class="text-sm font-bold text-slate-700">Actions</span>
            </th>
          </tr>
        </thead>

        <!-- Enhanced Table Body -->
        <tbody class="divide-y divide-slate-100">
          <% @departments.each do |department| %>
            <tr class="group hover:bg-pink-50/50 transition-colors duration-300">
              <td class="py-4 px-6">
                <span class="text-sm font-medium text-slate-900"><%= department.name %></span>
              </td>
              <td class="py-4 px-6">
                <% if department.manager %>
                  <div class="flex items-center space-x-3">
                    <div class="h-8 w-8 rounded-lg bg-gradient-to-r from-pink-500 to-purple-500 flex items-center justify-center text-white">
                      <i class="fas fa-user text-sm"></i>
                    </div>
                   <span class="text-sm text-slate-600"><%= department.manager.full_name %></span>

                  </div>
                <% else %>
                  <span class="text-sm text-slate-400">Non assigné</span>
                <% end %>
              </td>
              
              <!-- Enhanced Action Buttons -->
              <td class="py-4 px-6">
                <div class="flex items-center gap-2">
                  <%= link_to admin_department_path(department), 
                      class: "group flex items-center p-2.5 rounded-xl bg-pink-50 text-purple-500 hover:bg-gradient-to-r hover:from-pink-500 hover:to-purple-500 hover:text-white transition-all duration-300" do%>
                    <i class="fas fa-eye text-lg group-hover:scale-110 transition-transform duration-300"></i>
                  <% end %>

                  <%= link_to edit_admin_department_path(department), 
                      class: "group flex items-center p-2.5 rounded-xl bg-pink-50 text-pink-500 hover:bg-gradient-to-r hover:from-pink-500 hover:to-pink-500 hover:text-white transition-all duration-300" do %>
                    <i class="fas fa-edit text-lg group-hover:scale-110 transition-transform duration-300"></i>
                  <% end %>

                  <%= button_to admin_department_path(department),
                      method: :delete,
                      data: { turbo_confirm: "Êtes-vous sûr de vouloir supprimer ce département ?" },
                      class: "group flex items-center p-2.5 rounded-xl bg-pink-50 text-rose-500 hover:bg-gradient-to-r hover:from-pink-500 hover:to-purple-500 hover:text-white transition-all duration-300" do %>
                    <i class="fas fa-trash-alt text-lg group-hover:scale-110 transition-transform duration-300"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>